# ============================================================
# NutriAI Document Service - Environment Variables
# ============================================================

# Database
DATABASE_URL=postgresql://nutriai_user:nutriai_password@localhost:5432/nutriai

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=health-documents

# Azure Document Intelligence (OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Azure OpenAI (for document verification)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING=
